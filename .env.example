# ============================================
# RE AI Agents - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Bing News Search API (Azure Cognitive Services) ---
BING_NEWS_API_KEY=your-bing-news-api-key

# --- Gmail SMTP ---
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# --- Email Settings ---
EMAIL_FROM_NAME=NY地产日报
EMAIL_SUBJECT_PREFIX=[纽约地产AI日报]

# --- Schedule (cron expression, default: 7:00 AM EST daily) ---
CRON_SCHEDULE=0 7 * * *
CRON_TIMEZONE=America/New_York

# --- Optional ---
DRY_RUN=false
LOG_LEVEL=info
