# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Gmail SMTP ---
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# --- Email Settings ---
EMAIL_FROM_NAME=REscript
EMAIL_SUBJECT_PREFIX=[REscript]
SUPPORT_EMAIL=support@example.com
COMPANY_ADDRESS=123 Example St, New York, NY 10001

# --- Schedule ---
CRON_SCHEDULE=0 7 * * *
CRON_TIMEZONE=America/New_York

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID=price_your-stripe-price-id

# --- Security ---
ADMIN_TOKEN=change-me-to-a-strong-secret
VIEWER_TOKEN_SECRET=replace-with-a-different-long-random-secret

# --- App ---
BASE_URL=https://rescript.example.com

# --- Optional ---
DRY_RUN=false
LOG_LEVEL=info
